mobile_app/.env
mobile_app/.vscode/
mobile_app/.idea/
mobile_app/implementation_plan.md
mobile_app/*.iml

# ----------------------------------------------------------------------
# OS / IDE generated files
# ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
.idea/
.vscode/
*.rar

