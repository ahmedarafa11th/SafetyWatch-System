# SafetyWatch Monorepo .gitignore

# ----------------------------------------------------------------------
# AI / Data Science
# ----------------------------------------------------------------------
ai/violence_detection/checkpoints/*.h5
ai/violence_detection/checkpoints/*.hdf5
ai/violence_detection/__pycache__/
ai/violence_detection/*.pyc
ai/violence_detection/.env
ai/face_recognition/__pycache__/
ai/face_recognition/*.pyc
ai/face_recognition/.env
ai/face_recognition/*.tgz
ai/face_recognition/data/
ai/**/*.mp4
ai/**/*.avi
ai/**/*.jpg
ai/**/*.png

# ----------------------------------------------------------------------
# Backend (Laravel PHP)
# ----------------------------------------------------------------------
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/storage/logs/
backend/.env
backend/.env.backup
backend/.env.production
backend/.phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json
backend/npm-debug.log
backend/yarn-error.log
backend/.fleet
backend/.idea
backend/.vscode

# ----------------------------------------------------------------------
# Frontend (React / Vue / npm)
# ----------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/.vscode/

# ----------------------------------------------------------------------
# Mobile App (Flutter / React Native)
# ----------------------------------------------------------------------
mobile_app/node_modules/
mobile_app/build/
mobile_app/.dart_tool/
mobile_app/.pub-cache/
mobile_app/.pub/
mobile_app/android/.gradle/
mobile_app/android/app/build/
mobile_app/ios/Pods/
mobile_app/ios/.symlinks/
mobile_app/ios/Flutter/Flutter.podspec
mobile_app/.env
mobile_app/.vscode/

# ----------------------------------------------------------------------
# OS / IDE generated files
# ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
.idea/
.vscode/
