# SafetyWatch Monorepo .gitignore

# ----------------------------------------------------------------------
# AI / Data Science
# ----------------------------------------------------------------------
**/__pycache__/
*.pyc

# Violence Detection
ai/violence_detection/checkpoints/*.h5
ai/violence_detection/checkpoints/*.hdf5
ai/violence_detection/checkpoints/*.keras
ai/violence_detection/.env

# Face Recognition
ai/face_recognition/.env
ai/face_recognition/*.tgz
ai/face_recognition/lfw-funneled.tgz/
ai/face_recognition/data/
ai/face_recognition/embeddings.pkl
ai/face_recognition/results.csv

# AI media files
ai/**/*.mp4
ai/**/*.avi
ai/**/*.jpg
ai/**/*.png

# Docker compose backup & secrets
ai/docker-compose.yml.bak
ai/docker-compose.yml

# Edge config (generated at runtime)
**/edge_config.json

# ----------------------------------------------------------------------
# Backend (Laravel PHP)
# ----------------------------------------------------------------------
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/storage/logs/
backend/storage/app/public/faces/
backend/storage/app/public/test_videos/
backend/database/*.sqlite
backend/.env
backend/.env.backup
backend/.env.production
backend/.phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json
backend/npm-debug.log
backend/yarn-error.log
backend/.fleet
backend/.idea
backend/.vscode

# ----------------------------------------------------------------------
# Frontend (React / Vite)
# ----------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.env.production
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/.vscode/

# ----------------------------------------------------------------------
# Mobile App (Flutter)
# ----------------------------------------------------------------------
mobile_app/node_modules/
mobile_app/build/
mobile_app/.dart_tool/
mobile_app/.pub-cache/
mobile_app/.pub/
mobile_app/.flutter-plugins-dependencies
mobile_app/.metadata
mobile_app/android/.gradle/
mobile_app/android/app/build/
mobile_app/android/app/google-services.json
